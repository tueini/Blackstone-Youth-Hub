{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "target": "staging",
      "public": "public",
      "cleanUrls": true,
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ]
    }
  ],
  "functions": {
    "source": "functions"
  }
}